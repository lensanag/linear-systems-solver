      "method": "gauss-jordan",
      "description": {
        "es": "Sistema simbólico — análisis de casos (det = a²-4)",
        "en": "Symbolic system — case analysis (det = a²-4)"
      },
      "caseAnalysis": {
        "det": "a^2 - 4",
        "cases": [
          {
            "condition": "a ≠ 2, a ≠ -2",
            "description": { "es": "solución única", "en": "unique solution" }
          },
          {
            "condition": "a = 2",
            "description": { "es": "infinitas soluciones", "en": "infinitely many solutions" }
          },
          {
            "condition": "a = -2",
            "description": { "es": "sin solución", "en": "no solution" }
